# ── Copy this file to .env and fill in values ──────────────────
# Never commit .env to Git

# Domain + SSL (required for EC2 HTTPS deploy)
YGC_DOMAIN=chits-live.duckdns.org
YGC_SSL_EMAIL=admin@chits-live.duckdns.org

# Database
DB_NAME=ygcdb
DB_USERNAME=ygcuser
DB_PASSWORD=change_me_strong_password

# JWT (generate: openssl rand -base64 64)
JWT_SECRET=replace_with_64char_random_secret
JWT_EXPIRATION=86400000

# Mail (Gmail SMTP example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
